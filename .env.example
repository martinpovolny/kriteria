# Google OAuth2 — get these from https://console.cloud.google.com/apis/credentials
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8088/api/auth/callback

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET=

# Server config
ADDR=:8088
DB_PATH=data/kriteria.db
JSON_PATH=data/kriteria.json
DEV_MODE=true

# Edookit API (student sync)
EDOOKIT_API_URL=https://<school>.edookit.net
EDOOKIT_API_USER=
EDOOKIT_API_PASSWORD=
